generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

// =====================
// BUSINESS (Tenant)
// =====================
model Business {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  email       String
  phone       String?
  address     String?
  color       String   @default("#f59e0b")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers    Customer[]
  staff        Staff[]
  rewards      Reward[]
  transactions Transaction[]
  settings     BusinessSettings?
  invoices     Invoice[]
  campaigns    MarketingCampaign[]
}

// =====================
// BUSINESS SETTINGS
// =====================
model BusinessSettings {
  id               String  @id @default(cuid())
  businessId       String  @unique
  pointsPerPurchase Int    @default(1)
  rewardGoal       Int     @default(10)
  notifyOnReward   Boolean @default(true)
  emailEnabled     Boolean @default(false)
  whatsappEnabled  Boolean @default(false)
  smtpHost         String?
  smtpPort         Int?
  smtpUser         String?
  smtpPass         String?
  smtpFrom         String?
  telegramBotToken      String?
  telegramChatId        String?
  telegramWelcomeMsg    String?
  telegramRewardMsg     String?

  // WhatsApp CallMeBot
  whatsappApiUrl        String?
  whatsappApiKey        String?
  whatsappPhone         String?

  // Anti-cheat / Anti-fraud
  cooldownMinutes     Int     @default(30)
  maxPointsPerDay     Int     @default(0)
  maxPointsPerVisit   Int     @default(0)
  antiCheatEnabled    Boolean @default(true)

  // Marketing
  promoMessage         String?
  promoEnabled         Boolean @default(false)
  referralEnabled      Boolean @default(false)
  referralBonusPoints  Int     @default(0)

  // Billing
  plan                 String  @default("free")
  maxCustomers         Int     @default(100)
  maxStaff             Int     @default(3)
  maxRewards           Int     @default(5)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// CUSTOMER (per Business)
// =====================
model Customer {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  telegramChatId  String?
  whatsappPhone   String?
  totalPoints     Int      @default(0)
  visitsCount     Int      @default(0)
  businessId      String
  registeredAt    DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  redemptions  RewardRedemption[]
  @@unique([email, businessId])
}

// =====================
// STAFF (per Business)
// =====================
model Staff {
  id           String   @id @default(cuid())
  name         String
  email        String
  passwordHash String
  role         String   @default("staff")
  businessId   String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  @@unique([email, businessId])
}

// =====================
// REWARD (per Business)
// =====================
model Reward {
  id              String   @id @default(cuid())
  name            String
  description     String?
  imageUrl        String?
  requiredPoints  Int
  isActive        Boolean  @default(true)
  businessId      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  redemptions RewardRedemption[]
}

// =====================
// TRANSACTION (Points earn/redeem)
// =====================
model Transaction {
  id          String   @id @default(cuid())
  type        String   @default("earn")
  points      Int
  description String?
  customerId  String
  businessId  String
  staffId     String?
  createdAt   DateTime @default(now())

  customer    Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff       Staff?             @relation(fields: [staffId], references: [id], onDelete: SetNull)
  redemptions RewardRedemption[]
}

// =====================
// REWARD REDEMPTION
// =====================
model RewardRedemption {
  id            String   @id @default(cuid())
  customerId    String
  rewardId      String
  transactionId String
  redeemedAt    DateTime @default(now())

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reward     Reward      @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// =====================
// NOTIFICATION QUEUE
// =====================
model NotificationQueue {
  id         String   @id @default(cuid())
  businessId String
  customerId String
  channel    String
  subject    String?
  message    String
  status     String   @default("pending")
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  sentAt     DateTime?
}

// =====================
// INVOICE (Cobranzas)
// =====================
model Invoice {
  id          String   @id @default(cuid())
  businessId  String
  concept     String
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending")
  issueDate   String
  dueDate     String?
  dueHour     String?
  message     String?
  customerIds     String?
  reminderSent    Boolean  @default(false)
  reminderSentAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// =====================
// MARKETING CAMPAIGN
// =====================
model MarketingCampaign {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("promo")
  message     String
  target      String   @default("all")
  channel     String   @default("in_app")
  status      String   @default("draft")
  sentCount   Int      @default(0)
  businessId  String
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
